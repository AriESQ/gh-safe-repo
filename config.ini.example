# gh-safe-repo configuration
# Copy to ~/.config/gh-safe-repo/config.ini and edit as needed.
# All values shown here are the safe defaults — you only need to specify
# values you want to change.

[repo]
# Whether new repos are private by default
private = true

# Disable features that create clutter if unused
has_wiki = false
has_projects = false

# Issues are usually wanted
has_issues = true

# Clean up merged branches automatically
delete_branch_on_merge = true

# Merge strategy: squash-only is cleanest for most projects
allow_squash_merge = true
allow_merge_commit = false
allow_rebase_merge = true

# Do not initialize with a README — keeps the remote empty so pushing is seamless
auto_init = false

[actions]
# Which actions are allowed to run.
# Options: all, local_only, selected
allowed_actions = selected

# When allowed_actions = selected, these control which external actions are permitted:
# Allow actions maintained by GitHub (e.g. actions/checkout)
github_owned_allowed = true
# Allow actions from Marketplace verified creators
verified_allowed = true
# Comma-separated allowlist of specific actions/workflows (supports wildcards).
# Example: myorg/*, actions/setup-node@*
# patterns_allowed =

# Principle of least privilege: read-only by default
# Options: read, write
default_workflow_permissions = read

# Prevent Actions from approving pull requests
can_approve_pull_request_reviews = false

# Require workflows to pin actions to a specific commit SHA instead of a mutable tag
sha_pinning_required = true

# Require approval before running workflows on fork pull requests.
# Options: first_time_contributors_new_to_github, first_time_contributors, all_external_contributors
fork_pr_approval_policy = all_external_contributors

[branch_protection]
# Only applied to public repos (free plan) or any repo on a paid plan.
# Branch(es) to protect — comma-separated. The tool auto-detects your default
# branch at runtime; this is only used as a fallback when detection is unavailable.
protected_branch = master, main

# Require a pull request before merging to the protected branch
require_pull_request = true

# Number of approving reviews required
required_approving_reviews = 1

# Dismiss existing approvals when new commits are pushed
dismiss_stale_reviews = true

# Require all conversations to be resolved before merging
require_conversation_resolution = true

# Do not enforce these rules on administrators (allows admin pushes, e.g. for mirroring)
enforce_admins = false

# Block force-pushes to the protected branch
allow_force_pushes = false

# Block deletion of the protected branch
allow_deletions = false

# Use the Rulesets API instead of classic branch protection (same rules, adds bypass actors)
# use_rulesets = false

[tag_protection]
# Immutable tags via Rulesets API (same plan restrictions as branch protection).
# Glob pattern(s) for tags to protect — comma-separated.
protected_tags = *

# Prevent deletion of matching tags (git tag -d / git push --delete)
prevent_tag_deletion = true

# Prevent rewriting matching tags (git tag -f / force-push)
prevent_tag_update = true

[security]
# Enable Dependabot vulnerability alerts (public repos only on free plan)
enable_dependabot_alerts = true

# Auto-open PRs to fix vulnerable dependencies
enable_dependabot_security_updates = true

# Let security researchers report vulnerabilities privately
enable_private_vulnerability_reporting = true

# Block commits that contain supported secrets
enable_secret_scanning_push_protection = true

# Note: The following features have no REST API and must be configured via UI or dependabot.yml:
#   - Grouped security updates: use dependabot.yml groups with applies-to: security-updates
#   - Automatic dependency submission: enable via repository settings UI
#   - Dependency graph: automatic for public repos; enable via UI for private repos

[pre_flight_scan]
# Runs automatically when using --from --public, --local, or --audit.
# Scans the source locally before any code is copied or made public.
scan_for_secrets = true
scan_for_emails = true
scan_for_todos = true

# Scan git history for email addresses (requires scan_for_emails = true)
# scan_email_history = true
max_file_size_mb = 100

# Scanner selection: auto | native | docker | off
#   auto   — try native truffleHog on PATH, fall back to podman/docker container, then regex (default)
#   native — native truffleHog only; prints a warning and uses regex if not found
#   docker — container only (podman or docker); skip native PATH check
#   off    — regex scanner only; no truffleHog attempt, no warning
# trufflehog_mode = auto

# Literal strings to flag as critical findings (case-insensitive).
# Comma-separated, or one per line with continuation indentation.
# banned_strings = secret
#     password
#     credential

# Suppress email findings for specific addresses or entire domains.
# Entries starting with @ match all emails at that domain; otherwise exact address match.
# Case-insensitive, comma/newline separated.
# exclude_emails = action@github.com, noreply@github.com, @example.com

# Flag AI context files (CLAUDE.md, AGENTS.md, .cursorrules, etc.) as critical findings.
# Their git history may contain more sensitive content than the current version.
# warn_ai_context_files = true
