#!/usr/bin/env python3
"""
gh-safe-repo — Create GitHub repositories with safe defaults applied.

Usage:
    gh-safe-repo my-project              # Create private repo with safe defaults
    gh-safe-repo my-project --dry-run    # Preview without creating
    gh-safe-repo my-project --debug      # Show every API call
    gh-safe-repo my-project --no-wiki    # Override specific setting
"""

import argparse
import base64
import sys
from pathlib import Path

# Allow running from the repo root without installing
sys.path.insert(0, str(Path(__file__).parent))

from lib.config_manager import ConfigManager
from lib.diff import ChangeCategory, ChangeType
from lib.errors import APIError, AuthError, ConfigError, RepoExistsError, SafeRepoError
from lib.github_client import GitHubClient
from lib.plugins.actions import ActionsPlugin
from lib.plugins.branch_protection import BranchProtectionPlugin
from lib.plugins.repository import RepositoryPlugin
from lib.plugins.security import SecurityPlugin

try:
    from rich.console import Console
    from rich.panel import Panel
    from rich.table import Table
    from rich import print as rprint
    HAS_RICH = True
except ImportError:
    HAS_RICH = False


def build_console(stderr=False):
    if HAS_RICH:
        return Console(stderr=stderr)
    return None


def print_plan(plan, console):
    if HAS_RICH:
        table = Table(title="Planned Changes", show_header=True, header_style="bold")
        table.add_column("Type", style="cyan", width=8)
        table.add_column("Category", style="magenta", width=18)
        table.add_column("Setting", style="white", width=35)
        table.add_column("Value / Note", style="green")

        for change in plan.changes:
            if change.type == ChangeType.SKIP:
                table.add_row(
                    "[dim]SKIP[/dim]",
                    f"[dim]{change.category.value}[/dim]",
                    f"[dim]{change.key}[/dim]",
                    f"[dim]{change.reason}[/dim]",
                )
            elif change.type == ChangeType.ADD:
                table.add_row(
                    "[green]ADD[/green]",
                    change.category.value,
                    change.key,
                    str(change.new),
                )
            elif change.type == ChangeType.UPDATE:
                table.add_row(
                    "[yellow]UPDATE[/yellow]",
                    change.category.value,
                    change.key,
                    f"{change.old!r} → {change.new!r}",
                )
            elif change.type == ChangeType.DELETE:
                table.add_row(
                    "[red]DELETE[/red]",
                    change.category.value,
                    change.key,
                    str(change.old),
                )

        console.print(table)
    else:
        print("\nPlanned Changes:")
        print("-" * 60)
        for change in plan.changes:
            print(f"  {change.describe()}")
        print()


def print_success(owner, repo, console):
    url = f"https://github.com/{owner}/{repo}"
    if HAS_RICH:
        console.print(
            Panel(
                f"[green]Repository created successfully![/green]\n[link={url}]{url}[/link]",
                title="[bold green]Done[/bold green]",
            )
        )
    else:
        print(f"\nRepository created: {url}\n")


def create_security_md(client, owner, repo, config, dry_run=False):
    """Upload SECURITY.md to the new repo."""
    template_path = Path(__file__).parent / "lib" / "templates" / "SECURITY.md"
    if not template_path.exists():
        return

    contact_email = config.get("security", "contact_email", fallback="security@example.com")
    content = template_path.read_text().replace("{security_email}", contact_email)

    if dry_run:
        return  # Plan already shows FILE/SECURITY.md as ADD

    encoded = base64.b64encode(content.encode()).decode()
    path = client.repo_path(owner, repo, "contents/SECURITY.md")
    client.call_json("PUT", path, {
        "message": "Add SECURITY.md",
        "content": encoded,
    })


def check_repo_exists(client, owner, repo):
    """Return True if the repo already exists."""
    path = client.repo_path(owner, repo)
    status, _ = client.call_api("GET", path)
    return status == 200


def main():
    parser = argparse.ArgumentParser(
        prog="gh-safe-repo",
        description="Create GitHub repositories with safe defaults applied.",
    )
    parser.add_argument("repo", help="Name of the repository to create")
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Preview what would be configured without creating anything",
    )
    parser.add_argument(
        "--debug",
        action="store_true",
        help="Show every API call made",
    )
    parser.add_argument(
        "--no-wiki",
        action="store_true",
        help="Disable the wiki (also the default; overrides config)",
    )
    parser.add_argument(
        "--wiki",
        action="store_true",
        help="Enable the wiki",
    )
    parser.add_argument(
        "--enable-discussions",
        action="store_true",
        help="Enable GitHub Discussions",
    )
    parser.add_argument(
        "--public",
        action="store_true",
        help="Create a public repository instead of private",
    )
    parser.add_argument(
        "--config",
        metavar="PATH",
        help="Path to config file (default: ~/.config/gh-safe-repo/config.ini)",
    )

    args = parser.parse_args()

    console = build_console()
    err_console = build_console(stderr=True)

    def info(msg):
        if HAS_RICH:
            console.print(msg)
        else:
            print(msg)

    def error(msg):
        if HAS_RICH:
            err_console.print(f"[bold red]Error:[/bold red] {msg}")
        else:
            print(f"Error: {msg}", file=sys.stderr)

    def warn(msg):
        if HAS_RICH:
            err_console.print(f"[yellow]Warning:[/yellow] {msg}")
        else:
            print(f"Warning: {msg}", file=sys.stderr)

    # Load config
    try:
        config = ConfigManager(config_path=args.config)
    except ConfigError as e:
        error(str(e))
        sys.exit(1)

    # Apply CLI overrides
    overrides = {}
    if args.no_wiki:
        overrides[("repo", "has_wiki")] = "false"
    if args.wiki:
        overrides[("repo", "has_wiki")] = "true"
    if args.public:
        overrides[("repo", "private")] = "false"
    if overrides:
        config.apply_overrides(overrides)

    # Authenticate
    try:
        client = GitHubClient(debug=args.debug)
    except AuthError as e:
        error(str(e))
        sys.exit(1)

    # Detect owner
    try:
        owner = client.get_owner()
    except APIError as e:
        error(f"Could not determine GitHub user: {e}")
        sys.exit(1)

    repo_name = args.repo

    info(f"\nConfiguring [bold]{owner}/{repo_name}[/bold]..." if HAS_RICH else f"\nConfiguring {owner}/{repo_name}...")

    # Check repo doesn't already exist
    if not args.dry_run:
        try:
            if check_repo_exists(client, owner, repo_name):
                raise RepoExistsError(owner, repo_name)
        except RepoExistsError as e:
            error(str(e))
            sys.exit(1)
        except APIError as e:
            error(f"Failed to check if repo exists: {e}")
            sys.exit(1)

    # Run each plugin's plan()
    plugins = [
        RepositoryPlugin(client, owner, repo_name, config),
        ActionsPlugin(client, owner, repo_name, config),
        BranchProtectionPlugin(client, owner, repo_name, config),
        SecurityPlugin(client, owner, repo_name, config),
    ]

    from lib.diff import Change, ChangeCategory, ChangeType, Plan
    full_plan = Plan()

    for plugin in plugins:
        try:
            plugin_plan = plugin.plan()
            full_plan.merge(plugin_plan)
        except SafeRepoError as e:
            error(f"Planning failed: {e}")
            sys.exit(1)

    # Add SECURITY.md to the plan
    full_plan.add(Change(
        type=ChangeType.ADD,
        category=ChangeCategory.FILE,
        key="SECURITY.md",
        new="SECURITY.md (from template)",
    ))

    # Print the plan
    print_plan(full_plan, console)

    counts = full_plan.count_by_type()
    actionable = sum(v for k, v in counts.items() if k != ChangeType.SKIP)
    skipped = counts.get(ChangeType.SKIP, 0)

    if HAS_RICH:
        info(f"[dim]{actionable} change(s) to apply, {skipped} skipped (deferred to later phases)[/dim]")
    else:
        info(f"{actionable} change(s) to apply, {skipped} skipped")

    if args.dry_run:
        if HAS_RICH:
            info("\n[yellow]Dry run — no changes made.[/yellow]")
        else:
            info("\nDry run — no changes made.")
        sys.exit(0)

    # Apply changes
    repo_plugin = plugins[0]  # RepositoryPlugin
    actions_plugin = plugins[1]  # ActionsPlugin

    # Apply repo creation + settings
    try:
        repo_plugin.apply(full_plan)
    except RepoExistsError as e:
        error(str(e))
        sys.exit(1)
    except APIError as e:
        error(f"Failed to create repository: {e}")
        sys.exit(1)

    # Apply Actions settings
    try:
        actions_plugin.apply(full_plan)
    except APIError as e:
        warn(f"Repository created but Actions settings failed: {e}")

    # Create SECURITY.md
    try:
        create_security_md(client, owner, repo_name, config)
    except APIError as e:
        warn(f"Repository created but SECURITY.md upload failed: {e}")

    print_success(owner, repo_name, console)


if __name__ == "__main__":
    main()
